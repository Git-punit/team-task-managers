{
  "name": "team-task-manager-root",
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix \"frontend 2\"",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix \"frontend 2\"",
    "start": "npm start --prefix backend",
    "dev": "concurrently \"npm run start --prefix backend\" \"npm run dev --prefix \\\"frontend 2\\\"\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
